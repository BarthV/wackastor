# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5173/auth/discord/callback

# Superadmins (comma-separated Discord user IDs)
SUPERADMIN_DISCORD_IDS=

# Database (PostgreSQL)
# Dev local : démarrer Docker avec `docker compose up -d`
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wackastor
# Prod : URL Supabase non-poolée pour les migrations drizzle-kit
# POSTGRES_URL_NON_POOLING=postgres://...supabase.com:5432/postgres?sslmode=require
# Prod : URL poolée (PgBouncer) pour le runtime applicatif — injectée automatiquement par Vercel
# POSTGRES_URL=postgres://...pooler.supabase.com:6543/postgres?sslmode=require

# Vercel Cron secret
CRON_SECRET=

# UEXcorp API
UEXCORP_API_BASE=https://api.uexcorp.space/2.0
UEXCORP_API_KEY=
